# Google AI Studio (Gemini) API key — 무료 티어로 발급
# https://aistudio.google.com/apikey
GEMINI_API_KEY=your-key-here

# 사용할 모델 (기본: gemini-2.5-flash — 비용 우선)
GEMINI_MODEL=gemini-2.5-flash

# 유료 심층 리포트 전용 모델 (기본/무료 생성에서는 자동 사용하지 않음)
GEMINI_DEEP_MODEL=gemini-2.5-pro

# Upstash KV (Vercel Marketplace 통합 연결 시 자동 주입됨)
# Vercel 대시보드 > Storage > Upstash KV > Connect to project 하면
# `vercel env pull .env.local`로 아래 값들이 자동으로 받아진다.
KV_REST_API_URL=https://...upstash.io
KV_REST_API_TOKEN=...
# 참고용 — 코드는 위 두 개만 사용
# KV_URL=
# KV_REST_API_READ_ONLY_TOKEN=
# REDIS_URL=

# Supabase (Auth, 익명/정식 로그인)
# https://supabase.com/dashboard 의 프로젝트 > Settings > API 에서 복사
# Anonymous Sign-ins는 Authentication > Providers > Email > "Enable anonymous sign-ins" 토글 ON
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...
#
# 이메일 회원가입/로그인 + 게스트 전환을 위한 대시보드 설정:
#  1. Authentication > Providers > Email 활성화 (Confirm email 권장 ON)
#  2. Authentication > URL Configuration
#       - Site URL: 운영 도메인 (예: https://sajulife.example.com)
#       - Redirect URLs에 아래 추가:
#           http://localhost:3000/auth/confirm
#           https://<운영도메인>/auth/confirm
#  3. (선택) Email 템플릿을 token_hash 방식으로 쓰려면 Confirm/Change 템플릿 링크를
#     {{ .SiteURL }}/auth/confirm?token_hash={{ .TokenHash }}&type=email 로 교체.
#     기본 템플릿({{ .ConfirmationURL }}, PKCE code 방식)도 그대로 동작한다.

# 티켓 결제 — PortOne(아임포트) V2. https://admin.portone.io 콘솔에서 발급
# 테스트 채널은 PG 계약 없이도 무료로 만들 수 있어(콘솔 > 연동 관리 > 채널 관리),
# 실 결제 계약 전에 개발/검증용으로 먼저 쓸 수 있다.
# 상점 아이디 — 콘솔 > 결제 연동 > 연동 정보 우측 상단
NEXT_PUBLIC_PORTONE_STORE_ID=store-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# 채널 키 — 콘솔 > 결제 연동 > 채널 관리에서 채널 연동 후 확인
NEXT_PUBLIC_PORTONE_CHANNEL_KEY=channel-key-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# API Secret(V2) — 콘솔 > 결제 연동 > 연동 정보. 서버가 결제 검증(GET /payments/{id})에 쓴다.
# ★클라이언트에 절대 노출 금지(NEXT_PUBLIC_ 접두사 쓰지 말 것)★
PORTONE_API_SECRET=your-portone-v2-api-secret

# 관리자 화이트리스트 — 프롬프트 편집(/saju|/family|/tci|/fusion|/consult)/debug
# 권한을 가진 이메일들을 쉼표로 구분해 나열한다. 비교는 대소문자 무시.
# 비워두거나 미설정이면 관리자가 한 명도 없는 fail-closed 상태(모든 편집 차단).
# 운영팀이 사용한 Supabase 로그인 이메일과 정확히 일치해야 인식됨.
ADMIN_EMAILS=admin1@example.com,admin2@example.com

# 공유하기(공개 링크) — OG/카카오 카드의 절대 URL 기준 도메인.
# 미설정이면 요청 호스트로 자동 구성(로컬 개발은 자동, 운영은 등록 도메인 권장).
NEXT_PUBLIC_SITE_URL=https://sajulife.example.com

# 카카오톡 공유 — Kakao Developers > 내 애플리케이션 > 앱 키 > JavaScript 키.
# https://developers.kakao.com  (플랫폼 > Web 에 localhost:3000 + 운영 도메인 등록 필요)
# 미설정이면 공유 메뉴에서 '카카오톡' 버튼만 숨고 링크 복사/더보기는 정상 동작.
NEXT_PUBLIC_KAKAO_JS_KEY=your-kakao-javascript-key
